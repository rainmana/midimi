{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "midimi",
  "version": "0.1.0",
  "identifier": "com.midimi.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "midimi",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": { "../assets/soundfonts/GeneralUser-GS.sf2": "soundfonts/GeneralUser-GS.sf2", "../assets/demo/scale.mid": "demo/scale.mid" },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
